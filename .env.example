# ReservPlace API — Variables d'environnement
# Copiez ce fichier en .env et renseignez les valeurs

PORT=5000
NODE_ENV=development

# MongoDB Atlas — Chaîne de connexion
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxx.mongodb.net/?appName=Cluster0

# JWT
JWT_SECRET=votre_cle_secrete_longue_et_aleatoire
JWT_EXPIRES_IN=7d

# URL publique de l'API (localhost en dev, URL Render en prod)
API_URL=http://localhost:5000

# Gmail SMTP — App Password (https://myaccount.google.com/apppasswords)
SMTP_USER=noreply.reservplace@gmail.com
SMTP_PASS=votre_app_password_gmail
